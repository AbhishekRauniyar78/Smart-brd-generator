# Google Cloud
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
VERTEX_AI_LOCATION=us-central1

# Gemini model (Vertex AI)
GEMINI_MODEL=gemini-2.0-flash-001

# Optional: Google AI Studio API key (online mode without full GCP setup)
# Get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Cloud Storage
GCS_BUCKET_NAME=brd-agent-artifacts
GCS_INPUT_PREFIX=inputs/
GCS_OUTPUT_PREFIX=outputs/

# BigQuery
BQ_DATASET=brd_agent
BQ_DECISIONS_TABLE=decision_log
BQ_CONTEXT_TABLE=context_fragments

# Application
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8080
OFFLINE_MODE=true
